<!-- for showing the inforamtion of listing by its id name -->
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>

<body>
    <h3>Listings Details</h3>
    <ul>
        <li>
            <%=listing.title%>
        </li>
        <li>
            <%=listing.description%>
        </li>
        <li>
            <!-- for giving comma just like indian style -->
            ₹<%= listing.price.toLocaleString("en-IN")%>
        </li>
        <li>
            <%=listing.location%>
        </li>
        <li>
            <%=listing.country%>
        </li>
    </ul>
</body>

</html>