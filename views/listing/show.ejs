<!-- for showing the inforamtion of listing by its id name -->
<%layout("/layout/boilerplate")-%> 
<body>
    <h3>Listings Details</h3>
    <ul>
        <li>
            <%=listing.title%>
        </li>
        <li>
            <%=listing.description%>
        </li>
        <li>
            <!-- for giving comma just like indian style -->
            ₹<%= listing.price.toLocaleString("en-IN")%>
        </li>
        <li>
            <%=listing.location%>
        </li>
        <li>
            <%=listing.country%>
        </li>
    </ul>
    <a href="/listings/<%=listing._id%>/edit">Edit this listings</a><br><br>
    
    <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">   
        <button>Delete this Listing</button>
    </form>

</body>

